@page "/"
@rendermode InteractiveAuto
@using System.Globalization
@using System.Text.Json
@using Budget.Client.Components
@using Budget.Client.Models
@using Budget.Client.Repositories
@using Budget.Client.Services
@implements IAsyncDisposable
@inject ITransactionRepository TransactionRepository
@inject IMerchantMappingRepository MerchantMappingRepository
@inject IMerchantGroupRepository MerchantGroupRepository
@inject SyncStatusState SyncStatusState
@inject IJSRuntime JS

<PageTitle>Transactions</PageTitle>

<div class="month-picker">
    <button class="month-picker__nav" @onclick="PreviousMonth" aria-label="Previous month">&#8249;</button>
    <span class="month-picker__label">@Month.ToString("MMMM yyyy")</span>
    <button class="month-picker__nav" @onclick="NextMonth" aria-label="Next month">&#8250;</button>
</div>

<div class="page-columns">
    <div class="page-columns__main">
        <table>
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Amount</th>
                    <th>Merchant</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in TransactionList ?? [])
                {
                    <tr class="@(IsHighlighted(t) ? "row--highlighted" : "")" @onclick="() => ShowDetails(t)">
                        <td>@t.BookingDate?.ToString("dd.MM.yyyy")</td>
                        <td>@(t.CreditDebitIndicator == "CRDT" && t.EntryReference is not null ? "+" : "")@FormatCurrency(t.TransactionAmount.Currency)@FormatAmount(t.TransactionAmount.Value)</td>
                        <td>@t.Creditor?.Name</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="page-columns__sidebar" @ref="_sidebarRef">
        <GroupSummary Transactions="TransactionList" SelectedName="_selectedGroup" OnSelect="SelectGroup"/>
        <CreditorSummary Transactions="TransactionList" SelectedName="_selectedMerchant" OnSelect="SelectMerchant"/>
    </div>
</div>

@if (SelectedTransactionJson is not null)
{
    <div class="modal-backdrop" @onclick="CloseDetails">
        <div class="modal-box" @onclick:stopPropagation="true">
            <div class="modal-box__header">
                <span>Transaction</span>
                <button class="modal-box__close" @onclick="CloseDetails" aria-label="Close">&times;</button>
            </div>
            <pre class="modal-box__json">@SelectedTransactionJson</pre>
            <button class="modal-box__copy" @onclick="CopyToClipboard">Copy</button>
        </div>
    </div>
}

@code {
    private static readonly JsonSerializerOptions JsonOptions = new() { WriteIndented = true };

    private static string FormatCurrency(string currency) => currency switch
    {
        "EUR" => "€",
        "RUB" => "₽",
        _ => currency
    };

    private static string FormatAmount(string amount) =>
        decimal.Parse(amount, CultureInfo.InvariantCulture).ToString("0.00", CultureInfo.InvariantCulture);

    [PersistentState]
    public DateOnly Month { get; set; }

    [PersistentState]
    public List<TransactionDocument>? TransactionList { get; set; }

    [PersistentState]
    public List<MerchantMapping>? Mappings { get; set; }

    [PersistentState]
    public List<MerchantGroupAssignment>? GroupAssignments { get; set; }

    private string? SelectedTransactionJson { get; set; }
    private string? _selectedMerchant;
    private string? _selectedGroup;
    private Dictionary<string, string> _mappings = new();
    private Dictionary<string, string> _groupAssignments = new();
    private ElementReference _sidebarRef;
    private IJSObjectReference? _clickOutsideModule;
    private DotNetObjectReference<Transactions>? _dotNetRef;

    protected override async Task OnInitializedAsync()
    {
        SyncStatusState.SyncCompleted += OnSyncCompleted;

        if (TransactionList is not null)
        {
            _mappings = (Mappings ?? []).ToDictionary(m => m.MappedFrom, m => m.MappedTo);
            _groupAssignments = (GroupAssignments ?? []).ToDictionary(a => a.MerchantName, a => a.GroupName);
            return;
        }

        Month = new DateOnly(DateTime.Today.Year, DateTime.Today.Month, 1);
        Mappings = await MerchantMappingRepository.GetAll();
        GroupAssignments = await MerchantGroupRepository.GetAssignments();
        _mappings = Mappings.ToDictionary(m => m.MappedFrom, m => m.MappedTo);
        _groupAssignments = GroupAssignments.ToDictionary(a => a.MerchantName, a => a.GroupName);
        await LoadTransactions();
    }

    private void SelectMerchant(string? name)
    {
        _selectedMerchant = name;
        _selectedGroup = null;
    }

    private void SelectGroup(string? name)
    {
        _selectedGroup = name;
        _selectedMerchant = null;
    }

    private bool IsHighlighted(TransactionDocument t)
    {
        if (t.Creditor?.Name is null)
        {
            return false;
        }

        if (_selectedMerchant is not null)
        {
            return MerchantResolution.ResolveCanonicalName(t.Creditor.Name, _mappings) == _selectedMerchant;
        }

        if (_selectedGroup is not null)
        {
            return MerchantResolution.ResolveGroupName(t.Creditor.Name, _mappings, _groupAssignments) == _selectedGroup;
        }

        return false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            _clickOutsideModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/clickOutside.js");
            await _clickOutsideModule.InvokeVoidAsync("register", _dotNetRef, _sidebarRef);
        }
    }

    [JSInvokable]
    public void OnClickOutside()
    {
        if (_selectedMerchant is not null || _selectedGroup is not null)
        {
            _selectedMerchant = null;
            _selectedGroup = null;
            StateHasChanged();
        }
    }

    private void OnSyncCompleted()
    {
        _ = InvokeAsync(async () =>
        {
            await LoadTransactions();
            StateHasChanged();
        });
    }

    public async ValueTask DisposeAsync()
    {
        SyncStatusState.SyncCompleted -= OnSyncCompleted;

        if (_clickOutsideModule is not null)
        {
            try
            {
                await _clickOutsideModule.InvokeVoidAsync("unregister", _sidebarRef);
                await _clickOutsideModule.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                // The circuit is already tearing down (e.g. InteractiveAuto handing off to WebAssembly) - nothing to clean up.
            }
        }

        _dotNetRef?.Dispose();
    }

    private async Task PreviousMonth()
    {
        Month = Month.AddMonths(-1);
        await LoadTransactions();
    }

    private async Task NextMonth()
    {
        Month = Month.AddMonths(1);
        await LoadTransactions();
    }

    private async Task LoadTransactions()
    {
        var to = Month.AddMonths(1).AddDays(-1);
        TransactionList = await TransactionRepository.Get(Month, to);
    }

    private void ShowDetails(TransactionDocument transaction)
    {
        SelectedTransactionJson = JsonSerializer.Serialize(transaction, JsonOptions);
    }

    private void CloseDetails()
    {
        SelectedTransactionJson = null;
    }

    private async Task CopyToClipboard()
    {
        if (SelectedTransactionJson is not null)
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", SelectedTransactionJson);
        }
    }
}
