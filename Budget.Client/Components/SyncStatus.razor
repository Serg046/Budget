@rendermode InteractiveAuto
@using Budget.Client.Repositories
@using Microsoft.AspNetCore.Components
@inject ISyncStatusRepository SyncStatusRepository
@inject IJSRuntime JS

<div class="sync-status">
    <button class="sync-status__button" @onclick="Sync" aria-label="Sync" disabled="@_isSyncing">
        <svg class="sync-status__icon @(_isSyncing ? "sync-status__icon--spinning" : "")" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M23 4v6h-6"/>
            <path d="M1 20v-6h6"/>
            <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10"/>
            <path d="M20.49 15a9 9 0 0 1-14.85 3.36L1 14"/>
        </svg>
    </button>
    <span class="sync-status__text">@LastDataUpdate?.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
</div>

@code {
    [PersistentState]
    public DateTime? LastDataUpdate { get; set; }

    private bool _isSyncing;

    protected override async Task OnInitializedAsync()
    {
        if (LastDataUpdate is not null)
        {
            return;
        }

        await Load();
    }

    private async Task Load()
    {
        LastDataUpdate = await SyncStatusRepository.GetLastDataUpdate();
    }

    private async Task Sync()
    {
        var password = await JS.InvokeAsync<string?>("prompt", "Enter password:");
        if (string.IsNullOrEmpty(password))
        {
            return;
        }

        _isSyncing = true;

        var isValid = await SyncStatusRepository.ValidatePassword(password);
        if (isValid)
        {
            // TODO: wire up the actual synchronization action.
            await Load();
            await JS.InvokeVoidAsync("alert", "Success!");
        }
        else
        {
            await JS.InvokeVoidAsync("alert", "Incorrect password.");
        }

        _isSyncing = false;
    }
}
