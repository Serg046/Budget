@rendermode InteractiveAuto
@using Budget.Client.Repositories
@using Budget.Client.Services
@using Microsoft.AspNetCore.Components
@inject ISyncStatusRepository SyncStatusRepository
@inject SyncStatusState SyncStatusState
@inject NavigationManager NavigationManager

<div class="sync-status">
    <StatusBar/>
    <span class="sync-status__text sync-status__username">@Username</span>
    <div class="sync-status__row">
        @if (IsAdmin)
        {
            <button class="sync-status__button @(IsTokenExpiringSoon ? "sync-status__button--warning" : "")" @onclick="() => RefreshToken()" aria-label="Refresh Enable Banking token" disabled="@SyncStatusState.IsSyncing">
                <svg class="sync-status__icon @(_isRefreshingToken ? "sync-status__icon--pulsing" : "")" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="12 2 20 7 4 7"/>
                    <line x1="6" y1="11" x2="6" y2="18"/>
                    <line x1="10" y1="11" x2="10" y2="18"/>
                    <line x1="14" y1="11" x2="14" y2="18"/>
                    <line x1="18" y1="11" x2="18" y2="18"/>
                    <line x1="3" y1="22" x2="21" y2="22"/>
                </svg>
            </button>
        }
        <button class="sync-status__button" @onclick="Sync" aria-label="Sync" disabled="@(!IsAdmin || SyncStatusState.IsSyncing)">
            <svg class="sync-status__icon @(_isSyncing ? "sync-status__icon--spinning" : "")" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M23 4v6h-6"/>
                <path d="M1 20v-6h6"/>
                <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10"/>
                <path d="M20.49 15a9 9 0 0 1-14.85 3.36L1 14"/>
            </svg>
        </button>
        <span class="sync-status__text">@LastDataUpdate?.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
    </div>
</div>

@code {
    [PersistentState]
    public string? Username { get; set; }

    [PersistentState]
    public bool IsAdmin { get; set; }

    [PersistentState]
    public DateTime? LastDataUpdate { get; set; }

    [PersistentState]
    public bool IsTokenExpiringSoon { get; set; }

    private bool _isSyncing;
    private bool _isRefreshingToken;

    protected override async Task OnInitializedAsync()
    {
        if (LastDataUpdate is null)
        {
            await Load();
        }

        if (!RendererInfo.IsInteractive)
        {
            return;
        }

        var code = GetQueryParam("code");
        if (code is not null)
        {
            NavigationManager.NavigateTo(NavigationManager.Uri.Split('?')[0], replace: true);
            await RefreshToken(code);
        }
    }

    private string? GetQueryParam(string name)
    {
        var query = new Uri(NavigationManager.Uri).Query.TrimStart('?');
        foreach (var pair in query.Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var parts = pair.Split('=', 2);
            if (parts.Length == 2 && Uri.UnescapeDataString(parts[0]) == name)
            {
                return Uri.UnescapeDataString(parts[1]);
            }
        }

        return null;
    }

    private async Task Load()
    {
        Username = await SyncStatusRepository.GetUsername();
        IsAdmin = await SyncStatusRepository.IsAdmin();
        LastDataUpdate = await SyncStatusRepository.GetLastDataUpdate();
        IsTokenExpiringSoon = await SyncStatusRepository.IsTokenExpiringSoon();
    }

    private async Task Sync()
    {
        if (!IsAdmin)
        {
            return;
        }

        SyncStatusState.IsSyncing = true;
        _isSyncing = true;
        StateHasChanged();

        try
        {
            LastDataUpdate = await SyncStatusRepository.Sync();
            SyncStatusState.NotifySyncCompleted();
        }
        finally
        {
            SyncStatusState.IsSyncing = false;
            _isSyncing = false;
            StateHasChanged();
        }
    }

    private async Task RefreshToken(string? code = null)
    {
        if (!IsAdmin)
        {
            return;
        }

        SyncStatusState.IsSyncing = true;
        _isRefreshingToken = true;
        StateHasChanged();

        string? authUrl;
        try
        {
            authUrl = await SyncStatusRepository.RefreshToken(code);
        }
        finally
        {
            SyncStatusState.IsSyncing = false;
            _isRefreshingToken = false;
            StateHasChanged();
        }

        if (authUrl is not null)
        {
            NavigationManager.NavigateTo(authUrl, forceLoad: true);
        }
        else if (code is not null)
        {
            IsTokenExpiringSoon = false;
            await Sync();
        }
    }
}
